@using NetworkOptimizer.WiFi

@if (Loading)
{
    <div class="loading-state">
        <span class="spinner-sm"></span>
        <span>Loading...</span>
    </div>
}
else if (Issues.Count == 0 && !Score.HasValue)
{
    <div class="empty-state">
        <p>No Wi-Fi health data yet</p>
    </div>
}
else
{
    @if (Score.HasValue)
    {
        <HealthScoreGauge Score="@Score.Value" />
    }
    @if (Issues.Count > 0)
    {
        var shouldCollapse = Issues.Count > 4; // TODO: revert to 3 after testing
        <div class="wifi-issues-list">
            @if (!shouldCollapse)
            {
                @foreach (var issue in Issues)
                {
                    <div class="wifi-issue-item">
                        <div class="wifi-issue-row">
                            <span class="wifi-issue-icon wifi-severity-@issue.Severity.ToString().ToLowerInvariant()">
                                @((MarkupString)GetSeverityIcon(issue.Severity))
                            </span>
                            <span class="wifi-issue-title">@issue.Title</span>
                            @if (!string.IsNullOrEmpty(issue.AffectedEntity))
                            {
                                <span class="wifi-issue-entity">@issue.AffectedEntity</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(issue.Description))
                        {
                            <div class="wifi-issue-description">@issue.Description</div>
                        }
                    </div>
                }
            }
            else
            {
                @foreach (var group in Issues.GroupBy(i => i.Title))
                {
                    var groupCount = group.Count();
                    var groupKey = group.Key;
                    var isExpanded = _expandedGroups.Contains(groupKey);
                    var firstIssue = group.First();

                    <div class="wifi-issue-group">
                        <div class="wifi-issue-group-header @(isExpanded ? "expanded" : "")"
                             @onclick="() => ToggleGroup(groupKey)" @onclick:stopPropagation>
                            <span class="wifi-issue-icon wifi-severity-@firstIssue.Severity.ToString().ToLowerInvariant()">
                                @((MarkupString)GetSeverityIcon(firstIssue.Severity))
                            </span>
                            <span class="wifi-issue-title">@firstIssue.Title</span>
                            <span class="group-count-badge wifi-severity-@firstIssue.Severity.ToString().ToLowerInvariant()">@groupCount</span>
                            <span class="wifi-issue-chevron">@(isExpanded ? "\u25B2" : "\u25BC")</span>
                        </div>
                        <div class="expand-wrapper @(isExpanded ? "expanded" : "")">
                            <div class="expand-content">
                                @foreach (var issue in group)
                                {
                                    <div class="wifi-issue-nested">
                                        <div class="wifi-issue-nested-header">
                                            @if (!string.IsNullOrEmpty(issue.AffectedEntity))
                                            {
                                                <span class="wifi-issue-entity">@issue.AffectedEntity</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(issue.Description))
                                        {
                                            <div class="wifi-issue-description">@issue.Description</div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <p>No issues found - looking good!</p>
        </div>
    }
}

@code {
    [Parameter]
    public bool Loading { get; set; }

    [Parameter]
    public int? Score { get; set; }

    [Parameter]
    public List<HealthIssue> Issues { get; set; } = new();

    private HashSet<string> _expandedGroups = new();

    private void ToggleGroup(string key)
    {
        if (!_expandedGroups.Remove(key))
            _expandedGroups.Add(key);
    }

    private static string GetSeverityIcon(HealthIssueSeverity severity) => severity switch
    {
        HealthIssueSeverity.Critical => "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\" width=\"18\" height=\"18\"><path d=\"M12 2L3 7v6c0 5.25 3.85 10.15 9 11 5.15-.85 9-5.75 9-11V7l-9-5zm-1 14h2v2h-2v-2zm0-8h2v6h-2V8z\" opacity=\"0.2\"/><path d=\"M12 2L3 7v6c0 5.25 3.85 10.15 9 11 5.15-.85 9-5.75 9-11V7l-9-5zm0 2.18l7 3.89v5.43c0 4.14-3.01 8.05-7 8.88-3.99-.83-7-4.74-7-8.88V8.07l7-3.89zM11 8h2v6h-2V8zm0 8h2v2h-2v-2z\"/></svg>",
        HealthIssueSeverity.Warning => "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\" width=\"18\" height=\"18\"><path d=\"M1 21h22L12 2 1 21z\" opacity=\"0.2\"/><path d=\"M12 5.99L19.53 19H4.47L12 5.99M12 2L1 21h22L12 2zm1 14h-2v2h2v-2zm0-6h-2v4h2v-4z\"/></svg>",
        _ => "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\" width=\"18\" height=\"18\"><circle cx=\"12\" cy=\"12\" r=\"10\" opacity=\"0.2\"/><path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z\"/><rect x=\"11\" y=\"11\" width=\"2\" height=\"6\"/><rect x=\"11\" y=\"7\" width=\"2\" height=\"2\"/></svg>"
    };
}
