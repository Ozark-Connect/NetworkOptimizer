@page "/wan-steering"
@implements IDisposable
@inject WanSteerDeploymentService DeployService
@inject UniFiConnectionService ConnectionService
@inject IDbContextFactory<NetworkOptimizerDbContext> DbFactory
@inject IGatewaySshService GatewaySshService
@inject ILogger<WanSteering> Logger
@rendermode InteractiveServer
@using NetworkOptimizer.Storage.Models
@using NetworkOptimizer.Web.Services.Ssh
@using Microsoft.EntityFrameworkCore
@using System.Text.Json

<PageTitle>WAN Steering - Network Optimizer</PageTitle>

<div class="page-header">
    <h1>WAN Steering</h1>
    <p class="page-description">Policy-based multi-WAN traffic steering deployed to your UniFi gateway. Route traffic by source, destination, protocol, and port to specific WAN interfaces with health-check failover.</p>
</div>

@if (!ConnectionService.IsConnected && ConnectionService.IsInitialized && !string.IsNullOrEmpty(ConnectionService.LastError))
{
    <div class="connection-banner connection-error">
        <div class="banner-content">
            <span class="banner-icon">!</span>
            <div class="banner-text">
                <strong>UniFi Connection Error</strong>
                <span>@ConnectionService.LastError - WAN detection requires a working UniFi connection.</span>
            </div>
            <a href="/settings" class="btn btn-primary">Check Settings</a>
        </div>
    </div>
}

@if (!_gatewayConfigured && !_isLoading)
{
    <div class="card">
        <div class="card-body">
            <div class="alert alert-warning">
                <strong>Gateway SSH not configured.</strong>
                Go to <a href="/settings#gateway-ssh">Settings</a> to configure Gateway SSH credentials before using WAN Steering.
            </div>
        </div>
    </div>
}

<!-- Status Card -->
<div class="card">
    <div class="card-header">
        <h2 class="card-title">Daemon Status</h2>
        @if (!_isLoading)
        {
            <button class="btn btn-sm btn-secondary" @onclick="RefreshStatusAsync">Refresh</button>
        }
    </div>
    <div class="card-body">
        @if (_isLoading)
        {
            <div class="loading-container">
                <span class="spinner"></span>
                <span>Checking daemon status...</span>
            </div>
        }
        else if (_status == null)
        {
            <div class="empty-state">
                <p>Unable to retrieve status. Check gateway SSH connection.</p>
            </div>
        }
        else
        {
            <div class="ws-metrics">
                <div class="metric">
                    <div class="metric-label">Daemon</div>
                    <div class="metric-value">
                        <span class="status-dot @(_status.IsRunning ? "online" : "offline")"></span>
                        @(_status.IsRunning ? "Running" : "Stopped")
                    </div>
                </div>
                <div class="metric">
                    <div class="metric-label">Binary</div>
                    <div class="metric-value">
                        <span class="status-dot @(_status.BinaryDeployed ? "online" : "offline")"></span>
                        @(_status.BinaryDeployed ? "Deployed" : "Not Deployed")
                    </div>
                </div>
                @if (_status.Version != null)
                {
                    <div class="metric">
                        <div class="metric-label">Version</div>
                        <div class="metric-value">@_status.Version</div>
                    </div>
                }
                @if (_parsedStatus != null)
                {
                    <div class="metric">
                        <div class="metric-label">Uptime</div>
                        <div class="metric-value">@FormatUptime(_parsedStatus.StartedAt)</div>
                    </div>
                    <div class="metric">
                        <div class="metric-label">Rules</div>
                        <div class="metric-value">@_parsedStatus.RuleCount</div>
                    </div>
                    <div class="metric">
                        <div class="metric-label">Reconciles</div>
                        <div class="metric-value">@_parsedStatus.ReconcileCount</div>
                    </div>
                }
            </div>

            @if (_parsedStatus?.WanHealth != null && _parsedStatus.WanHealth.Count > 0)
            {
                <div class="ws-health-section">
                    <strong class="ws-section-label">WAN Health</strong>
                    <div class="ws-metrics">
                        @foreach (var kvp in _parsedStatus.WanHealth)
                        {
                            <div class="metric">
                                <div class="metric-label">@kvp.Key</div>
                                <div class="metric-value">
                                    <span class="status-dot @(kvp.Value.Healthy ? "online" : "offline")"></span>
                                    @(kvp.Value.Healthy ? "Healthy" : "Unhealthy")
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- WAN Interfaces Card -->
<div class="card">
    <div class="card-header">
        <h2 class="card-title">WAN Interfaces</h2>
        <button class="btn btn-sm btn-secondary" @onclick="DiscoverWansAsync" disabled="@_isDiscovering">
            @if (_isDiscovering)
            {
                <span class="spinner spinner-sm"></span>
                <span>Discovering...</span>
            }
            else
            {
                <span>Refresh</span>
            }
        </button>
    </div>
    <div class="card-body">
        @if (_wanInterfaces.Count == 0)
        {
            <div class="empty-state">
                <p>No WAN interfaces discovered. Ensure the UniFi Console is connected and the gateway has WAN connections configured.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Interface</th>
                            <th>Gateway IP</th>
                            <th>FW Mark</th>
                            <th>Health Target</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var wan in _wanInterfaces)
                        {
                            <tr>
                                <td>@wan.Name</td>
                                <td><code>@wan.Interface</code></td>
                                <td>@(wan.GatewayIp ?? "—")</td>
                                <td><code>@(string.IsNullOrEmpty(wan.FWMark) ? "—" : wan.FWMark)</code></td>
                                <td>@wan.HealthTarget</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Traffic Rules Card -->
<div class="card">
    <div class="card-header">
        <h2 class="card-title">Traffic Rules</h2>
        @if (_editingRuleId == null)
        {
            <button class="btn btn-sm btn-primary" @onclick="AddRule">Add Rule</button>
        }
    </div>
    <div class="card-body">
        @if (_rules.Count == 0 && _editingRuleId == null)
        {
            <div class="empty-state">
                <p>No traffic rules configured. Add a rule to steer traffic to a specific WAN interface.</p>
            </div>
        }
        else
        {
            @foreach (var rule in _rules)
            {
                @if (_editingRuleId == rule.Id)
                {
                    @RenderEditForm()
                }
                else
                {
                    <div class="ws-rule-item">
                        <div class="ws-rule-row">
                            <div class="ws-rule-left">
                                <label class="checkbox-label" data-tooltip="@(rule.Enabled ? "Enabled" : "Disabled")">
                                    <input type="checkbox" checked="@rule.Enabled" @onchange="@(e => ToggleRuleEnabled(rule, (bool)(e.Value ?? false)))" />
                                </label>
                                <div class="ws-rule-info">
                                    <div class="ws-rule-name @(rule.Enabled ? "" : "ws-rule-disabled")">@rule.Name</div>
                                    <div class="ws-rule-match">@BuildMatchSummary(rule)</div>
                                </div>
                            </div>
                            <div class="ws-rule-actions">
                                @if (rule.Probability < 1.0)
                                {
                                    <span class="ws-rule-probability">@((rule.Probability * 100).ToString("F0")) %</span>
                                }
                                <span class="status-badge status-active">@rule.TargetWanKey</span>
                                <div class="ws-sort-buttons">
                                    <button class="btn btn-sm btn-secondary" @onclick="@(() => MoveRuleUp(rule))" disabled="@(rule.SortOrder == 0)" data-tooltip="Move up">&#9650;</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="@(() => MoveRuleDown(rule))" disabled="@(rule.SortOrder >= _rules.Count - 1)" data-tooltip="Move down">&#9660;</button>
                                </div>
                                <button class="btn btn-sm btn-secondary" @onclick="@(() => EditRule(rule))">Edit</button>
                                <button class="btn btn-sm btn-danger" @onclick="@(() => DeleteRule(rule))">Delete</button>
                            </div>
                        </div>
                    </div>
                }
            }
        }

        @if (_editingRuleId == 0)
        {
            @RenderEditForm()
        }
    </div>
</div>

<!-- Deploy Controls Card -->
<div class="card">
    <div class="card-header">
        <h2 class="card-title">Deploy</h2>
    </div>
    <div class="card-body">
        <div class="ws-deploy-buttons">
            <button class="btn btn-primary" @onclick="DeployAsync" disabled="@_isDeploying">
                @if (_isDeploying)
                {
                    <span class="spinner spinner-sm"></span>
                    <span>Deploying...</span>
                }
                else
                {
                    <span>Deploy</span>
                }
            </button>
            <button class="btn btn-secondary" @onclick="ReloadConfigAsync" disabled="@_isDeploying" data-tooltip="Upload latest config and signal daemon to reload">Reload Config</button>
            <button class="btn btn-secondary" @onclick="StopAsync" disabled="@_isDeploying">Stop</button>
            <button class="btn btn-danger btn-sm" @onclick="RemoveAsync" disabled="@_isDeploying" data-tooltip="Stop daemon and remove all files from gateway">Remove</button>
        </div>

        @if (!string.IsNullOrEmpty(_deployMessage))
        {
            <div class="@(_deploySuccess ? "alert alert-success" : "alert alert-danger") ws-deploy-alert">
                @_deployMessage
            </div>
        }

        @if (_deploySteps.Count > 0)
        {
            <div class="ws-deploy-steps">
                @foreach (var step in _deploySteps)
                {
                    <div>@step</div>
                }
            </div>
        }
    </div>
</div>

<style>
    /* Compact metrics grid for status display */
    .ws-metrics {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 1rem;
    }

    .ws-metrics .metric-value {
        font-size: 0.9rem;
        font-weight: 500;
    }

    .ws-health-section {
        margin-top: 1rem;
    }

    .ws-section-label {
        font-size: 0.875rem;
        color: var(--text-secondary);
    }

    .ws-health-section .ws-metrics {
        margin-top: 0.5rem;
    }

    /* Form grid layouts */
    .ws-form-row-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .ws-form-row-3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1rem;
    }

    @@media (max-width: 768px) {
        .ws-form-row-2,
        .ws-form-row-3 {
            grid-template-columns: 1fr;
        }
    }

    /* Rule items */
    .ws-rule-item {
        background: var(--bg-primary);
        border: 1px solid var(--bg-tertiary);
        border-radius: 0.5rem;
        padding: 0.75rem 1rem;
        margin-bottom: 0.75rem;
    }

    .ws-rule-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .ws-rule-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex: 1;
        min-width: 0;
    }

    .ws-rule-info {
        min-width: 0;
    }

    .ws-rule-name {
        font-weight: 600;
        color: var(--text-primary);
    }

    .ws-rule-name.ws-rule-disabled {
        color: var(--text-muted);
    }

    .ws-rule-match {
        font-size: 0.8rem;
        color: var(--text-muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ws-rule-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-shrink: 0;
    }

    .ws-rule-probability {
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

    .ws-sort-buttons {
        display: flex;
        gap: 0.25rem;
    }

    /* Edit form card */
    .ws-edit-card {
        background: var(--bg-primary);
        border: 1px solid var(--primary-color);
        border-radius: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .ws-edit-card .card-body {
        padding: 1rem;
    }

    .ws-enabled-checkbox {
        margin-top: 0.5rem;
    }

    .ws-edit-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    /* Deploy controls */
    .ws-deploy-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
    }

    .ws-deploy-alert {
        margin-top: 1rem;
    }

    .ws-deploy-steps {
        margin-top: 0.75rem;
        font-size: 0.8rem;
        color: var(--text-muted);
    }

    @@media (max-width: 768px) {
        .ws-rule-row {
            flex-direction: column;
            align-items: flex-start;
        }

        .ws-rule-actions {
            flex-wrap: wrap;
        }
    }
</style>

@code {
    // State
    private bool _isLoading = true;
    private bool _isDeploying;
    private bool _isDiscovering;
    private bool _gatewayConfigured;
    private string? _deployMessage;
    private bool _deploySuccess;
    private List<string> _deploySteps = new();

    // Data
    private List<WanSteerTrafficClass> _rules = new();
    private List<WanSteerWanInfo> _wanInterfaces = new();
    private WanSteerStatus? _status;
    private ParsedDaemonStatus? _parsedStatus;

    // Rule editing
    private int? _editingRuleId; // null = not editing, 0 = adding new, >0 = editing existing
    private WanSteerTrafficClass _editForm = new();
    private string _editSrcCidrs = "";
    private string _editSrcMacs = "";
    private string _editDstCidrs = "";
    private string _editSrcPorts = "";
    private string _editDstPorts = "";
    private string _editProtocol = "";
    private int _editProbabilityPercent = 100;

    // Status polling timer
    private System.Threading.Timer? _pollTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadRulesAsync();
        await RefreshStatusAsync();
        await DiscoverWansAsync();

        // Poll status every 10 seconds
        _pollTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    await RefreshStatusQuietAsync();
                    StateHasChanged();
                });
            }
            catch { /* prevent timer death */ }
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    // --- Data Loading ---

    private async Task LoadRulesAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _rules = await db.WanSteerTrafficClasses
                .OrderBy(r => r.SortOrder)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load WAN Steer traffic rules");
        }
    }

    private async Task RefreshStatusAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var settings = await GatewaySshService.GetSettingsAsync();
            _gatewayConfigured = settings.Enabled && settings.HasCredentials && !string.IsNullOrEmpty(settings.Host);

            if (_gatewayConfigured)
            {
                _status = await DeployService.GetStatusAsync();
                ParseStatusJson();
            }
            else
            {
                _status = null;
                _parsedStatus = null;
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Failed to refresh WAN Steer status");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>Silent status refresh for the polling timer (no loading spinner).</summary>
    private async Task RefreshStatusQuietAsync()
    {
        if (!_gatewayConfigured) return;

        try
        {
            _status = await DeployService.GetStatusAsync();
            ParseStatusJson();
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Failed to poll WAN Steer status");
        }
    }

    private async Task DiscoverWansAsync()
    {
        _isDiscovering = true;
        StateHasChanged();

        try
        {
            _wanInterfaces = await DeployService.DiscoverWanInterfacesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Failed to discover WAN interfaces");
        }
        finally
        {
            _isDiscovering = false;
            StateHasChanged();
        }
    }

    // --- Rule CRUD ---

    private void AddRule()
    {
        _editingRuleId = 0;
        _editForm = new WanSteerTrafficClass
        {
            Name = "",
            Enabled = true,
            Probability = 1.0,
            SortOrder = _rules.Count,
            TargetWanKey = _wanInterfaces.FirstOrDefault()?.NetworkGroup ?? ""
        };
        PopulateEditFields();
    }

    private void EditRule(WanSteerTrafficClass rule)
    {
        _editingRuleId = rule.Id;
        _editForm = new WanSteerTrafficClass
        {
            Id = rule.Id,
            Name = rule.Name,
            Enabled = rule.Enabled,
            Probability = rule.Probability,
            SortOrder = rule.SortOrder,
            TargetWanKey = rule.TargetWanKey,
            SrcCidrsJson = rule.SrcCidrsJson,
            SrcMacsJson = rule.SrcMacsJson,
            DstCidrsJson = rule.DstCidrsJson,
            Protocol = rule.Protocol,
            SrcPortsJson = rule.SrcPortsJson,
            DstPortsJson = rule.DstPortsJson
        };
        PopulateEditFields();
    }

    private void PopulateEditFields()
    {
        _editSrcCidrs = ParseJsonArray(_editForm.SrcCidrsJson);
        _editSrcMacs = ParseJsonArray(_editForm.SrcMacsJson);
        _editDstCidrs = ParseJsonArray(_editForm.DstCidrsJson);
        _editSrcPorts = ParseJsonArrayToCommaSeparated(_editForm.SrcPortsJson);
        _editDstPorts = ParseJsonArrayToCommaSeparated(_editForm.DstPortsJson);
        _editProtocol = _editForm.Protocol ?? "";
        _editProbabilityPercent = (int)Math.Round(_editForm.Probability * 100);
    }

    private async Task SaveRule()
    {
        // Map edit fields back to the form
        _editForm.SrcCidrsJson = ToJsonArray(_editSrcCidrs);
        _editForm.SrcMacsJson = ToJsonArray(_editSrcMacs);
        _editForm.DstCidrsJson = ToJsonArray(_editDstCidrs);
        _editForm.SrcPortsJson = ToJsonArrayFromCommaSeparated(_editSrcPorts);
        _editForm.DstPortsJson = ToJsonArrayFromCommaSeparated(_editDstPorts);
        _editForm.Protocol = string.IsNullOrWhiteSpace(_editProtocol) ? null : _editProtocol;
        _editForm.Probability = _editProbabilityPercent / 100.0;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            if (_editingRuleId == 0)
            {
                // New rule
                _editForm.SortOrder = _rules.Count;
                db.WanSteerTrafficClasses.Add(_editForm);
            }
            else
            {
                // Update existing
                var existing = await db.WanSteerTrafficClasses.FindAsync(_editForm.Id);
                if (existing != null)
                {
                    existing.Name = _editForm.Name;
                    existing.Enabled = _editForm.Enabled;
                    existing.Probability = _editForm.Probability;
                    existing.TargetWanKey = _editForm.TargetWanKey;
                    existing.SrcCidrsJson = _editForm.SrcCidrsJson;
                    existing.SrcMacsJson = _editForm.SrcMacsJson;
                    existing.DstCidrsJson = _editForm.DstCidrsJson;
                    existing.Protocol = _editForm.Protocol;
                    existing.SrcPortsJson = _editForm.SrcPortsJson;
                    existing.DstPortsJson = _editForm.DstPortsJson;
                }
            }

            await db.SaveChangesAsync();
            await LoadRulesAsync();
            _editingRuleId = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save traffic rule");
        }
    }

    private void CancelEdit()
    {
        _editingRuleId = null;
    }

    private async Task DeleteRule(WanSteerTrafficClass rule)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = await db.WanSteerTrafficClasses.FindAsync(rule.Id);
            if (entity != null)
            {
                db.WanSteerTrafficClasses.Remove(entity);
                await db.SaveChangesAsync();

                // Re-number sort orders
                var remaining = await db.WanSteerTrafficClasses.OrderBy(r => r.SortOrder).ToListAsync();
                for (int i = 0; i < remaining.Count; i++)
                    remaining[i].SortOrder = i;
                await db.SaveChangesAsync();
            }

            await LoadRulesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete traffic rule");
        }
    }

    private async Task ToggleRuleEnabled(WanSteerTrafficClass rule, bool enabled)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = await db.WanSteerTrafficClasses.FindAsync(rule.Id);
            if (entity != null)
            {
                entity.Enabled = enabled;
                await db.SaveChangesAsync();
            }
            rule.Enabled = enabled;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to toggle rule enabled state");
        }
    }

    private async Task MoveRuleUp(WanSteerTrafficClass rule)
    {
        var idx = _rules.IndexOf(rule);
        if (idx <= 0) return;

        await SwapRuleSortOrders(_rules[idx], _rules[idx - 1]);
    }

    private async Task MoveRuleDown(WanSteerTrafficClass rule)
    {
        var idx = _rules.IndexOf(rule);
        if (idx < 0 || idx >= _rules.Count - 1) return;

        await SwapRuleSortOrders(_rules[idx], _rules[idx + 1]);
    }

    private async Task SwapRuleSortOrders(WanSteerTrafficClass a, WanSteerTrafficClass b)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entityA = await db.WanSteerTrafficClasses.FindAsync(a.Id);
            var entityB = await db.WanSteerTrafficClasses.FindAsync(b.Id);
            if (entityA != null && entityB != null)
            {
                (entityA.SortOrder, entityB.SortOrder) = (entityB.SortOrder, entityA.SortOrder);
                await db.SaveChangesAsync();
            }
            await LoadRulesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to reorder rules");
        }
    }

    // --- Deploy Actions ---

    private async Task DeployAsync()
    {
        _isDeploying = true;
        _deployMessage = null;
        _deploySteps.Clear();
        StateHasChanged();

        try
        {
            var progress = new Progress<string>(step =>
            {
                _deploySteps.Add(step);
                InvokeAsync(StateHasChanged);
            });

            var (success, error) = await DeployService.DeployAsync(progress);
            _deploySuccess = success;
            _deployMessage = success ? "WAN Steer deployed successfully." : error;

            await RefreshStatusQuietAsync();
        }
        catch (Exception ex)
        {
            _deploySuccess = false;
            _deployMessage = ex.Message;
        }
        finally
        {
            _isDeploying = false;
            StateHasChanged();
        }
    }

    private async Task ReloadConfigAsync()
    {
        _isDeploying = true;
        _deployMessage = null;
        _deploySteps.Clear();
        StateHasChanged();

        try
        {
            var (success, error) = await DeployService.ReloadConfigAsync();
            _deploySuccess = success;
            _deployMessage = success ? "Configuration reloaded." : error;
        }
        catch (Exception ex)
        {
            _deploySuccess = false;
            _deployMessage = ex.Message;
        }
        finally
        {
            _isDeploying = false;
            StateHasChanged();
        }
    }

    private async Task StopAsync()
    {
        _isDeploying = true;
        _deployMessage = null;
        _deploySteps.Clear();
        StateHasChanged();

        try
        {
            await DeployService.StopAsync();
            _deploySuccess = true;
            _deployMessage = "Daemon stopped.";
            await RefreshStatusQuietAsync();
        }
        catch (Exception ex)
        {
            _deploySuccess = false;
            _deployMessage = ex.Message;
        }
        finally
        {
            _isDeploying = false;
            StateHasChanged();
        }
    }

    private async Task RemoveAsync()
    {
        _isDeploying = true;
        _deployMessage = null;
        _deploySteps.Clear();
        StateHasChanged();

        try
        {
            var (success, error) = await DeployService.RemoveAsync();
            _deploySuccess = success;
            _deployMessage = success ? "WAN Steer removed from gateway." : error;
            await RefreshStatusQuietAsync();
        }
        catch (Exception ex)
        {
            _deploySuccess = false;
            _deployMessage = ex.Message;
        }
        finally
        {
            _isDeploying = false;
            StateHasChanged();
        }
    }

    // --- JSON Helpers ---

    /// <summary>Parse a JSON string array to newline-separated text for textarea display.</summary>
    private static string ParseJsonArray(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return "";
        try
        {
            var arr = JsonSerializer.Deserialize<List<string>>(json);
            return arr != null ? string.Join("\n", arr) : "";
        }
        catch { return ""; }
    }

    /// <summary>Parse a JSON string array to comma-separated text for input display.</summary>
    private static string ParseJsonArrayToCommaSeparated(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return "";
        try
        {
            var arr = JsonSerializer.Deserialize<List<string>>(json);
            return arr != null ? string.Join(",", arr) : "";
        }
        catch { return ""; }
    }

    /// <summary>Convert newline-separated textarea text to a JSON string array. Null if empty.</summary>
    private static string? ToJsonArray(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return null;
        var items = text.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .ToList();
        return items.Count > 0 ? JsonSerializer.Serialize(items) : null;
    }

    /// <summary>Convert comma-separated text to a JSON string array. Null if empty.</summary>
    private static string? ToJsonArrayFromCommaSeparated(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return null;
        var items = text.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .ToList();
        return items.Count > 0 ? JsonSerializer.Serialize(items) : null;
    }

    // --- Display Helpers ---

    private static string BuildMatchSummary(WanSteerTrafficClass rule)
    {
        var parts = new List<string>();

        if (rule.DstCidrsJson != null)
        {
            try
            {
                var cidrs = JsonSerializer.Deserialize<List<string>>(rule.DstCidrsJson);
                if (cidrs?.Count > 0)
                    parts.Add("dst: " + string.Join(", ", cidrs.Take(2)) + (cidrs.Count > 2 ? $" +{cidrs.Count - 2}" : ""));
            }
            catch { }
        }

        if (rule.SrcCidrsJson != null)
        {
            try
            {
                var cidrs = JsonSerializer.Deserialize<List<string>>(rule.SrcCidrsJson);
                if (cidrs?.Count > 0)
                    parts.Add("src: " + string.Join(", ", cidrs.Take(2)) + (cidrs.Count > 2 ? $" +{cidrs.Count - 2}" : ""));
            }
            catch { }
        }

        if (rule.Protocol != null)
        {
            var proto = rule.Protocol;
            if (rule.DstPortsJson != null)
            {
                try
                {
                    var ports = JsonSerializer.Deserialize<List<string>>(rule.DstPortsJson);
                    if (ports?.Count > 0)
                        proto += ":" + string.Join(",", ports.Take(3)) + (ports.Count > 3 ? "..." : "");
                }
                catch { }
            }
            parts.Add(proto);
        }

        if (rule.SrcMacsJson != null)
        {
            try
            {
                var macs = JsonSerializer.Deserialize<List<string>>(rule.SrcMacsJson);
                if (macs?.Count > 0)
                    parts.Add("mac: " + string.Join(", ", macs.Take(2)) + (macs.Count > 2 ? $" +{macs.Count - 2}" : ""));
            }
            catch { }
        }

        return parts.Count > 0 ? string.Join(" | ", parts) : "Match all traffic";
    }

    private static string FormatUptime(DateTime startedAt)
    {
        if (startedAt == default) return "—";
        var span = DateTime.UtcNow - startedAt;
        if (span.TotalDays >= 1)
            return $"{(int)span.TotalDays}d {span.Hours}h";
        if (span.TotalHours >= 1)
            return $"{(int)span.TotalHours}h {span.Minutes}m";
        return $"{(int)span.TotalMinutes}m";
    }

    // --- Status JSON Parsing ---

    private void ParseStatusJson()
    {
        _parsedStatus = null;
        if (string.IsNullOrWhiteSpace(_status?.StatusJson)) return;

        try
        {
            _parsedStatus = JsonSerializer.Deserialize<ParsedDaemonStatus>(_status.StatusJson, _jsonOptions);
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Failed to parse WAN Steer status JSON");
        }
    }

    private static readonly JsonSerializerOptions _jsonOptions = new()
    {
        PropertyNameCaseInsensitive = true,
        PropertyNamingPolicy = JsonNamingPolicy.SnakeCaseLower
    };

    // --- Edit Form Render Fragment ---

