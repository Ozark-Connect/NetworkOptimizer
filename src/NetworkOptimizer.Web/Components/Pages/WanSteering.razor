            <div class="card-body">
                <div class="form-group">
                    <label class="form-label">Name</label>
                    <input type="text" class="form-control" @bind="_editForm.Name" placeholder="e.g., Steam Downloads" />
                </div>

                <div class="ws-form-row-2">
                    <div class="form-group">
                        <label class="form-label">Source CIDRs</label>
                        <textarea class="form-control" rows="3" @bind="_editSrcCidrs" placeholder="One CIDR per line, e.g., 192.168.1.0/24"></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Destination CIDRs</label>
                        <textarea class="form-control" rows="3" @bind="_editDstCidrs" placeholder="One CIDR per line, e.g., 162.254.192.0/21"></textarea>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Source MACs</label>
                    <textarea class="form-control" rows="2" @bind="_editSrcMacs" placeholder="One MAC per line"></textarea>
                    <span class="form-help">From your UniFi device list</span>
                </div>

                <div class="ws-form-row-3">
                    <div class="form-group">
                        <label class="form-label">Protocol</label>
                        <select class="form-control" @bind="_editProtocol">
                            <option value="">Any</option>
                            <option value="tcp">TCP</option>
                            <option value="udp">UDP</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Source Ports</label>
                        <input type="text" class="form-control" @bind="_editSrcPorts" placeholder="443,8080,27015:27030" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Destination Ports</label>
                        <input type="text" class="form-control" @bind="_editDstPorts" placeholder="443,8080,27015:27030" />
                    </div>
                </div>

                <div class="ws-form-row-3">
                    <div class="form-group">
                        <label class="form-label">Probability <span class="tooltip-icon tooltip-icon-sm" data-tooltip="Percentage of matching connections to steer. 100% = all matching traffic. 50% = load balance half to this WAN.">?</span></label>
                        <input type="number" class="form-control" @bind="_editProbabilityPercent" min="1" max="100" />
                        <span class="form-help">100 = all matching traffic</span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Target WAN</label>
                        <select class="form-control" @bind="_editForm.TargetWanKey">
                            @if (_wanInterfaces.Count == 0)
                            {
                                <option value="">No WANs discovered</option>
                            }
                            @foreach (var wan in _wanInterfaces)
                            {
                                <option value="@wan.NetworkGroup">@wan.Name (@wan.Interface)</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Enabled</label>
                        <label class="checkbox-label ws-enabled-checkbox">
                            <input type="checkbox" @bind="_editForm.Enabled" />
                            <span>Rule is active</span>
                        </label>
                    </div>
                </div>

                <div class="ws-edit-actions">
                    <button class="btn btn-primary btn-sm" @onclick="SaveRule">Save</button>
                    <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">Cancel</button>
                </div>
            </div>
        </div>
    };

    // --- Cleanup ---

    public void Dispose()
    {
        _pollTimer?.Dispose();
    }

    // --- Parsed Status Model ---

    private class ParsedDaemonStatus
    {
        public string Version { get; set; } = "";
        public bool Running { get; set; }
        public DateTime StartedAt { get; set; }
        public DateTime LastReconcile { get; set; }
        public int RuleCount { get; set; }
        public int ReconcileCount { get; set; }
        public Dictionary<string, ParsedWanHealth> WanHealth { get; set; } = new();
    }

    private class ParsedWanHealth
    {
        public bool Healthy { get; set; }
        public int FailCount { get; set; }
        public int PassCount { get; set; }
        public DateTime LastCheck { get; set; }
    }
}
