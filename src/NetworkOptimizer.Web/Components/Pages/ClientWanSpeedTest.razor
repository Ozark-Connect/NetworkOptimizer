@page "/client-wan-speedtest"
@rendermode InteractiveServer
@implements IDisposable
@using NetworkOptimizer.Web.Services
@using NetworkOptimizer.Storage.Models
@using NetworkOptimizer.Storage.Helpers
@using NetworkOptimizer.Web.Components.Shared
@using NetworkOptimizer.Core.Helpers
@inject ClientSpeedTestService ClientSpeedTestService
@inject SystemSettingsService SettingsService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject PullToRefreshState PtrState

<PageTitle>Client WAN Speed Test - Network Optimizer</PageTitle>

<a href="/wan-speedtest" class="back-link" title="Back to WAN Speed Test">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
    </svg>
</a>

<div class="page-header">
    <h1>Client WAN Speed Test</h1>
    <p class="page-description">Test internet speed from any device using an external speed test server</p>
</div>

<div class="client-speedtest-container">
    @if (!_serverConfigured)
    {
        <div class="card">
            <div class="card-body">
                <div class="empty-state">
                    <span class="empty-icon">🌐</span>
                    <h3>External Speed Test Server Not Configured</h3>
                    <p>To use Client WAN Speed Tests, configure an external OpenSpeedTest server in Settings.</p>
                    <a href="/settings#external-speedtest-settings" class="btn btn-primary">Configure External Server</a>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Run Speed Test Card -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">Run a Speed Test</h2>
            </div>
            <div class="card-body">
                <div class="test-options">
                    <div class="test-option">
                        <div class="test-option-header">
                            <h3>Browser Speed Test</h3>
                            @if (!string.IsNullOrEmpty(_serverName))
                            {
                                <span class="badge badge-wan">@_serverName</span>
                            }
                            <a href="/settings#external-speedtest-settings" class="tooltip-icon settings-link" data-tooltip="Server settings">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M7.84 1.804A1 1 0 018.82 1h2.36a1 1 0 01.98.804l.331 1.652a6.993 6.993 0 011.929 1.115l1.598-.54a1 1 0 011.186.447l1.18 2.044a1 1 0 01-.205 1.251l-1.267 1.113a7.047 7.047 0 010 2.228l1.267 1.113a1 1 0 01.206 1.25l-1.18 2.045a1 1 0 01-1.187.447l-1.598-.54a6.993 6.993 0 01-1.929 1.115l-.33 1.652a1 1 0 01-.98.804H8.82a1 1 0 01-.98-.804l-.331-1.652a6.993 6.993 0 01-1.929-1.115l-1.598.54a1 1 0 01-1.186-.447l-1.18-2.044a1 1 0 01.205-1.251l1.267-1.114a7.05 7.05 0 010-2.227L1.821 7.773a1 1 0 01-.206-1.25l1.18-2.045a1 1 0 011.187-.447l1.598.54A6.993 6.993 0 017.51 3.456l.33-1.652zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
                                </svg>
                            </a>
                        </div>
                        <p>
                            Run a speed test against the external server. This measures your internet speed (WAN) -
                            traffic goes from your device, out through your WAN, across the internet to the remote server, and back.
                        </p>
                        <div class="test-option-actions">
                            <a href="@(_serverUrl)?Run" target="_blank" rel="opener" class="btn btn-primary">
                                Run WAN Speed Test
                            </a>
                            <span class="form-help">Opens in a new tab and auto-starts</span>
                        </div>
                        <div class="url-copy-row">
                            <input type="text" class="url-display" value="@_serverUrl" readonly />
                            <button type="button" class="btn-icon" title="Copy URL" onclick="copyFromInput(this)">
                                <span class="copy-icon">📋</span>
                                <span class="copy-check" style="display:none;">✓</span>
                            </button>
                        </div>
                        <p class="form-help browser-tip">
                            <strong>Tip:</strong> Share this URL with any device on your network to test WAN speed from that device.
                        </p>
                        @if (_showHttpsWarning)
                        {
                            <div class="alert alert-warning" style="margin-top: 1rem;">
                                <strong>HTTPS Strongly Recommended:</strong> This server is configured over HTTP. Most browsers (Chrome, Edge, Safari) will block speed test results from posting back due to Private Network Access restrictions. HTTPS with a reverse proxy is strongly recommended.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Test History -->
        <div class="card">
            <div class="card-header history-card-header">
                <div class="header-title-row">
                    <h2 class="card-title">Test History</h2>
                    <div class="header-actions">
                        <button class="btn btn-sm btn-secondary" @onclick="LoadResults" disabled="@_loading">
                            @if (_loading)
                            {
                                <span class="spinner"></span>
                                <span>Loading...</span>
                            }
                            else
                            {
                                <span>Refresh</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body">
                @if (_results.Count > 0)
                {
                    <div class="table-responsive" id="history-table">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Device</th>
                                    <th class="hide-mobile">
                                        <span class="tooltip-wrapper tooltip-bottom">
                                            ↓ Mbps
                                            <span class="tooltip-icon">?</span>
                                            <span class="tooltip-content">
                                                <strong>From Device</strong><br />
                                                Data transferred from the client device through WAN to the external server.
                                            </span>
                                        </span>
                                    </th>
                                    <th class="hide-mobile">
                                        <span class="tooltip-wrapper tooltip-bottom">
                                            ↑ Mbps
                                            <span class="tooltip-icon">?</span>
                                            <span class="tooltip-content">
                                                <strong>To Device</strong><br />
                                                Data transferred from the external server through WAN to the client device.
                                            </span>
                                        </span>
                                    </th>
                                    <th class="show-mobile">Mbps</th>
                                    <th class="hide-mobile">Ping</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var result in _pagedResults)
                                {
                                    var isExpanded = _expandedId == result.Id;
                                    <tr id="result-@result.Id"
                                        class="history-row-clickable @(isExpanded ? "history-row-expanded" : "")"
                                        @onclick="@(() => ToggleExpand(result.Id))">
                                        <td>@result.TestTime.ToLocalTime().ToString("MMM dd HH:mm")</td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(result.DeviceName))
                                            {
                                                <span>@result.DeviceName</span>
                                                <br />
                                                <code class="text-muted">@result.DeviceHost</code>
                                            }
                                            else
                                            {
                                                <code>@result.DeviceHost</code>
                                            }
                                        </td>
                                        <td class="hide-mobile">
                                            @if (result.DownloadMbps > 0)
                                            {
                                                <span class="speed-value">@result.DownloadMbps.ToString("F1")</span>
                                                <span class="speed-unit">Mbps</span>
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>
                                        <td class="hide-mobile">
                                            @if (result.UploadMbps > 0)
                                            {
                                                <span class="speed-value">@result.UploadMbps.ToString("F1")</span>
                                                <span class="speed-unit">Mbps</span>
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>
                                        <td class="show-mobile">@($"{(result.DownloadMbps > 0 ? $"↓{result.DownloadMbps:F0}" : "")}{(result.DownloadMbps > 0 && result.UploadMbps > 0 ? " " : "")}{(result.UploadMbps > 0 ? $"↑{result.UploadMbps:F0}" : "")}")</td>
                                        <td class="hide-mobile">
                                            @if (result.PingMs.HasValue)
                                            {
                                                <span>@(result.PingMs.Value % 1 == 0 && result.PingMs.Value >= 10 ? result.PingMs.Value.ToString("F0") : result.PingMs.Value.ToString("F1")) ms</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td class="expand-chevron">
                                            <span>@(isExpanded ? "▲" : "▼")</span>
                                        </td>
                                    </tr>
                                    <tr class="history-details-row">
                                        <td colspan="7">
                                            <div class="expand-wrapper @(isExpanded ? "expanded" : "")">
                                                <div class="expand-content">
                                                    <div class="history-details">
                                                        <SpeedTestDetails Result="result"
                                                                          UseWanLabels="true"
                                                                          OnDelete="HandleDelete"
                                                                          OnNotesChanged="HandleNotesChanged"
                                                                          IsInTableRow="true" />
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (_totalPages > 1)
                    {
                        <div class="pagination">
                            <button class="btn btn-sm btn-secondary" disabled="@(_page <= 1)" @onclick="() => ChangePage(-1)">Prev</button>
                            <span class="pagination-info">Page @_page of @_totalPages (@_results.Count total)</span>
                            <button class="btn btn-sm btn-secondary" disabled="@(_page >= _totalPages)" @onclick="() => ChangePage(1)">Next</button>
                        </div>
                    }
                }
                else if (!_loading)
                {
                    <div class="empty-state">
                        <p>No WAN speed tests recorded yet.</p>
                        <p class="form-help">Run a speed test from any device to see results here.</p>
                    </div>
                }
            </div>
        </div>

        <!-- How it Works -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">How it Works</h2>
            </div>
            <div class="card-body">
                <div class="info-section">
                    <h4>WAN Speed Test via External Server</h4>
                    <ol>
                        <li>Open the speed test URL from any device on your network</li>
                        <li>The test runs in your browser against the external server</li>
                        <li>Traffic flows: your device → your WAN → internet → external server → internet → your WAN → your device</li>
                        <li>Results are automatically reported back to Network Optimizer</li>
                        <li>Device is identified by IP address and matched to UniFi client list</li>
                    </ol>
                    <p class="form-help">
                        <strong>Note:</strong> This tests your internet (WAN) speed, not your LAN speed.
                        Use the <a href="/client-speedtest">Client Speed Test</a> page to test LAN speed.
                    </p>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .back-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: var(--border-radius);
        color: var(--text-secondary);
        background: var(--bg-tertiary);
        transition: all 0.15s ease;
        margin-bottom: 0.75rem;
    }

    .back-link:hover {
        color: var(--text-primary);
        background: var(--bg-hover);
    }

    .client-speedtest-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .test-options {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .test-option {
        background: var(--bg-tertiary);
        border-radius: var(--border-radius);
        padding: 1.25rem;
    }

    .test-option-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .test-option-header h3 {
        margin: 0;
        font-size: 1rem;
    }

    .settings-link {
        margin-left: auto;
        color: var(--text-muted);
        transition: color 0.15s;
    }

    .settings-link:hover {
        color: var(--text-primary);
    }

    .test-option p {
        margin: 0 0 1rem;
        color: var(--text-secondary);
        font-size: 0.875rem;
    }

    .test-option-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem 1rem;
        flex-wrap: wrap;
    }

    .test-option .browser-tip {
        margin-top: 1rem;
    }

    .url-copy-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1rem;
        padding: 0.5rem;
        background: var(--bg-primary);
        border-radius: var(--border-radius);
    }

    .url-display {
        flex: 1;
        font-size: 0.8125rem;
        color: var(--text-secondary);
        word-break: break-all;
        background: transparent;
        border: none;
        outline: none;
        font-family: monospace;
        width: 100%;
    }

    .btn-icon {
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0.25rem;
        font-size: 1rem;
        opacity: 0.7;
        transition: opacity 0.15s;
    }

    .btn-icon:hover {
        opacity: 1;
    }

    .copy-check {
        color: var(--success-color);
    }

    .speed-value {
        font-weight: 600;
        font-size: 1rem;
    }

    .speed-unit {
        color: var(--text-muted);
        font-size: 0.75rem;
        margin-left: 0.25rem;
    }

    .badge-wan {
        background: rgba(59, 130, 246, 0.2);
        color: #60a5fa;
    }

    .history-card-header {
        flex-direction: column;
        align-items: stretch;
        gap: 0.75rem;
    }

    .header-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
</style>

@code {
    private bool _serverConfigured;
    private string _serverUrl = "";
    private string _serverName = "";
    private bool _showHttpsWarning;
    private bool _loading;
    private List<Iperf3Result> _results = new();
    private int _expandedId;
    private int _page = 1;
    private const int PageSize = 20;
    private System.Threading.Timer? _pollTimer;

    private int _totalPages => Math.Max(1, (int)Math.Ceiling(_results.Count / (double)PageSize));
    private IEnumerable<Iperf3Result> _pagedResults => _results.Skip((_page - 1) * PageSize).Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        PtrState.RefreshCallback = () => LoadResults();
        PtrState.NotifyStateChanged = StateHasChanged;

        var settings = await SettingsService.GetExternalSpeedTestSettingsAsync();
        _serverConfigured = settings.IsConfigured;
        _serverUrl = settings.Url;
        _serverName = settings.Name;

        // Show HTTPS warning when external server is not HTTPS.
        // Browser loads page from external server (public origin), then XHRs results
        // back to Network Optimizer (private LAN). Private Network Access requires
        // the origin to be a secure context (HTTPS) to access private addresses.
        _showHttpsWarning = settings.Scheme != "https";

        if (_serverConfigured)
        {
            await LoadResults();
        }

        // Poll for new results every 10 seconds
        _pollTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    await LoadResults();
                    StateHasChanged();
                });
            }
            catch { }
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private async Task LoadResults()
    {
        _loading = true;
        try
        {
            _results = await ClientSpeedTestService.GetWanResultsAsync(200);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ToggleExpand(int id)
    {
        _expandedId = _expandedId == id ? 0 : id;
    }

    private void ChangePage(int delta)
    {
        _page = Math.Clamp(_page + delta, 1, _totalPages);
    }

    private async Task HandleDelete(int id)
    {
        await ClientSpeedTestService.DeleteResultAsync(id);
        await LoadResults();
    }

    private async Task HandleNotesChanged((int Id, string? Notes) args)
    {
        await ClientSpeedTestService.UpdateNotesAsync(args.Id, args.Notes);
        await LoadResults();
    }

    public void Dispose()
    {
        _pollTimer?.Dispose();
    }
}
