@inherits LayoutComponentBase
@using NetworkOptimizer.Web.Services
@using System.Reflection
@inject UniFiConnectionService ConnectionService

<div class="app-container">
    <div class="sidebar-overlay @(sidebarOpen ? "visible" : "")" @onclick="CloseSidebar"></div>
    <div class="sidebar @(sidebarOpen ? "open" : "")">
        <a href="/" class="sidebar-header" @onclick="CloseSidebar">
            <img src="images/network-optimizer-logo.png" alt="Network Optimizer" class="sidebar-logo" />
            <p class="app-subtitle"><strong>for UniFi</strong></p>
        </a>
        <NavMenu OnNavigate="CloseSidebar" />
    </div>

    <div class="main-content">
        <header class="top-bar">
            <button class="hamburger-btn" @onclick="ToggleSidebar" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <a href="/" class="mobile-logo">
                <img src="images/network-optimizer-logo.png" alt="Network Optimizer" />
            </a>
            <div class="status-indicators">
                @if (ConnectionService.IsConnected)
                {
                    <div class="status-item status-connected">
                        <span class="status-icon">●</span>
                        <span>Console Connected</span>
                    </div>
                }
                else
                {
                    <div class="status-item status-disconnected">
                        <span class="status-icon">●</span>
                        <span>Console Disconnected</span>
                    </div>
                }
            </div>
            <div class="header-actions">
                <a href="/api/auth/logout" class="logout-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                    </svg>
                    <span>Logout</span>
                </a>
            </div>
        </header>

        <main class="page-content">
            <article class="content">
                @Body
            </article>
        </main>

        <footer class="app-footer">
            <p>&copy; 2026 Ozark Connect - Network Optimizer @(Assembly.GetExecutingAssembly().GetCustomAttribute<System.Reflection.AssemblyInformationalVersionAttribute>()?.InformationalVersion is string v && !v.StartsWith("0.0.0") ? $"v{v}" : "(source build)")</p>
        </footer>
    </div>
</div>

<ScrollRestoration />

<script>
    // Mobile: hide top bar on scroll down, show on scroll up; collapse identity bar; show footer at bottom
    (function() {
        var scrollEl = document.querySelector('.page-content');
        if (!scrollEl) return;
        var lastScrollTop = 0;
        var threshold = 10;

        scrollEl.addEventListener('scroll', function() {
            if (window.innerWidth > 768) return;
            var st = scrollEl.scrollTop;
            var topBar = document.querySelector('.top-bar');
            var footer = document.querySelector('.app-footer');
            var maxScroll = scrollEl.scrollHeight - scrollEl.clientHeight;

            // Top bar: hide on scroll down, show on scroll up
            if (Math.abs(st - lastScrollTop) > threshold) {
                if (st > lastScrollTop && st > 60) {
                    topBar.classList.add('top-bar-hidden');
                } else {
                    topBar.classList.remove('top-bar-hidden');
                }
                lastScrollTop = st;
            }

            // Client dashboard: collapse identity name/meta when scrolled past
            var identityBar = document.querySelector('.identity-bar');
            if (identityBar) {
                var barBottom = identityBar.offsetTop + identityBar.offsetHeight;
                if (st > barBottom - 20) {
                    identityBar.classList.add('identity-collapsed');
                } else {
                    identityBar.classList.remove('identity-collapsed');
                }
            }

            // Footer: only show near bottom
            if (footer) {
                if (maxScroll - st < 50) {
                    footer.classList.add('footer-visible');
                } else {
                    footer.classList.remove('footer-visible');
                }
            }
        }, { passive: true });
    })();
</script>

@code {
    private bool sidebarOpen = false;

    private void ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
    }

    private void CloseSidebar()
    {
        sidebarOpen = false;
        StateHasChanged();
    }
}
